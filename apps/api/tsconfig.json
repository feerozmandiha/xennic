{
  "extends": "../../packages/config/tsconfig.base.json",

  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "types": ["node"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext"
  },

  "include": ["src/**/*.ts"],

  "exclude": [
    "src/**/*.spec.ts",
    "test"
  ]
}