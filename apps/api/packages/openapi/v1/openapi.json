t"},{"name":"users","description":"User profile management"},{"name":"roles","description":"Role management and assignment"},{"name":"permissions","description":"Permission management"},{"name":"projects","description":"Project management"},{"name":"engineering","description":"Engineering calculations"}],"servers":[],"components":{"securitySchemes":{"JWT-auth":{"scheme":"bearer","bearerFormat":"JWT","type":"http","name":"JWT","description":"Enter JWT token","in":"header"}},"schemas":{"CreateWorkspaceDto":{"type":"object","properties":{"name":{"type":"string","description":"Workspace display name","example":"Engineering Workspace","minLength":2,"maxLength":100}},"required":["name"]},"WorkspaceResponseDto":{"type":"object","properties":{"id":{"type":"string","description":"Workspace unique identifier (UUIDv7)","example":"464e54bb-5e81-426f-ab75-39226f6f8980"},"code":{"type":"string","description":"Unique workspace code (auto-generated)","example":"ENGINEERING_WORKSPACE1_7LGG"},"name":{"type":"string","description":"Workspace display name","example":"Engineering Workspace"},"createdBy":{"type":"string","description":"ID of user who created the workspace","example":"user-123"},"updatedBy":{"type":"object","description":"ID of last user who updated the workspace","nullable":true,"example":"user-456"},"createdAt":{"format":"date-time","type":"string","description":"Creation timestamp","example":"2026-06-03T02:59:44.524Z"},"updatedAt":{"format":"date-time","type":"string","description":"Last update timestamp","example":"2026-06-03T02:59:44.524Z"},"isDeleted":{"type":"boolean","description":"Soft delete status","example":false}},"required":["id","code","name","createdBy","updatedBy","createdAt","updatedAt","isDeleted"]},"UpdateWorkspaceDto":{"type":"object","properties":{}},"CreateUserHttpDto":{"type":"object","properties":{"email":{"type":"string","example":"user@example.com","description":"User email address"},"firstName":{"type":"string","example":"John","description":"First name","minLength":2,"maxLength":50},"lastName":{"type":"string","example":"Doe","description":"Last name","minLength":2,"maxLength":50},"password":{"type":"string","example":"SecurePass123!","description":"Password"},"phone":{"type":"string","example":"+1234567890","description":"Phone number"}},"required":["email","firstName","lastName","password"]},"UserResponseDto":{"type":"object","properties":{"id":{"type":"string"},"email":{"type":"string"},"firstName":{"type":"string"},"lastName":{"type":"string"},"status":{"type":"string"},"isEmailVerified":{"type":"boolean"},"createdAt":{"format":"date-time","type":"string"},"updatedAt":{"format":"date-time","type":"string"}},"required":["id","email","firstName","lastName","status","isEmailVerified","createdAt","updatedAt"]},"UpdateUserHttpDto":{"type":"object","properties":{"firstName":{"type":"string","example":"John","description":"First name"},"lastName":{"type":"string","example":"Doe","description":"Last name"},"phone":{"type":"string","example":"+1234567890","description":"Phone number"}}},"RegisterDto":{"type":"object","properties":{"email":{"type":"string","example":"user@example.com","description":"User email address"},"firstName":{"type":"string","example":"John","description":"First name","minLength":2,"maxLength":50},"lastName":{"type":"string","example":"Doe","description":"Last name","minLength":2,"maxLength":50},"password":{"type":"string","example":"SecurePass123!","description":"Password (min 8 chars, with uppercase, lowercase, number, special char)"},"phone":{"type":"string","example":"+1234567890","description":"Phone number (optional)"}},"required":["email","firstName","lastName","password"]},"AuthResponseDto":{"type":"object","properties":{"accessToken":{"type":"string"},"refreshToken":{"type":"string"},"expiresIn":{"type":"number","example":900},"tokenType":{"type":"string","example":"Bearer"},"user":{"type":"object"}},"required":["accessToken","refreshToken","expiresIn","tokenType","user"]},"LoginDto":{"type":"object","properties":{"email":{"type":"string","example":"user@example.com","description":"User email address"},"password":{"type":"string","example":"SecurePass123!","description":"User password"}},"required":["email","password"]},"RefreshTokenDto":{"type":"object","properties":{"refreshToken":{"type":"string","description":"Refresh token"}},"required":["refreshToken"]},"ForgotPasswordDto":{"type":"object","properties":{"email":{"type":"string","example":"user@example.com","description":"User email address"}},"required":["email"]},"ResetPasswordDto":{"type":"object","properties":{"token":{"type":"string","description":"Password reset token"},"newPassword":{"type":"string","example":"NewSecurePass123!","description":"New password"}},"required":["token","newPassword"]},"ChangePasswordDto":{"type":"object","properties":{"currentPassword":{"type":"string","description":"Current password"},"newPassword":{"type":"string","description":"New password"}},"required":["currentPassword","newPassword"]},"RoleResponseDto":{"type":"object","properties":{"id":{"type":"string","description":"Role unique identifier"},"name":{"type":"string","description":"Role display name"},"slug":{"type":"string","description":"Unique role slug"},"description":{"type":"object","description":"Role description","nullable":true},"createdAt":{"format":"date-time","type":"string","description":"Creation timestamp"},"updatedAt":{"format":"date-time","type":"string","description":"Last update timestamp"}},"required":["id","name","slug","description","createdAt","updatedAt"]},"CreateRoleDto":{"type":"object","properties":{"name":{"type":"string","example":"Engineer","description":"Role display name"},"slug":{"type":"string","example":"ENGINEER","description":"Unique role slug (uppercase, underscore)"},"description":{"type":"string","example":"Can perform engineering calculations","description":"Role description"}},"required":["name","slug"]},"UpdateRoleDto":{"type":"object","properties":{"