{
  "name": "@xennic/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nest start --watch",
    "typecheck": "tsc --noEmit",
    "build": "tsc && pnpm generate:openapi",
    "export:openapi": "tsx scripts/export-openapi.ts",
    "generate:openapi": "node --import tsx scripts/generate-openapi.ts"
  },
  "dependencies": {
    "@fastify/multipart": "^10.0.0",
    "@nestjs/common": "^11.1.24",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.24",
    "@nestjs/platform-express": "^11.1.24",
    "@nestjs/platform-fastify": "^11.1.24",
    "@prisma/client": "^6.19.3",
    "@xennic/database": "workspace:*",
    "@xennic/shared": "workspace:*",
    "@xennic/types": "workspace:*",
    "minio": "^8.0.7",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@types/node": "^25.9.1",
    "prisma": "^6.19.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4"
  }
}
