// ============================================================
// XENNIC PLATFORM — Prisma Schema v2
// ORM:      Prisma
// DB:       PostgreSQL 17
// Strategy: Multi-Tenant (workspace_id isolation)
// Keys:     UUID (all business entities)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// IDENTITY DOMAIN
// ============================================================

model users {
  id               String    @id @default(uuid())
  email            String    @unique
  phone            String?   @unique
  password         String    // hashed — Argon2id
  first_name       String
  last_name        String
  avatar_file_id   String?
  is_admin         Boolean   @default(false)
  is_active        Boolean   @default(true)
  email_verified_at DateTime?
  last_login       DateTime?
  created_by       String?
  updated_by       String?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt
  deleted_at       DateTime?

  sessions         sessions[]
  refresh_tokens   refresh_tokens[]
  user_roles       user_roles[]
  workspace_members workspace_members[]
  workspace_invitations_sent workspace_invitations[] @relation("InvitedBy")
  projects_created projects[]        @relation("ProjectCreatedBy")
  project_members  project_members[]
  project_notes    project_notes[]
  calculations     calculations[]
  files            files[]
  notifications    notifications[]
  audit_logs       audit_logs[]
  ai_usage         ai_usage[]
  orders           orders[]
  payment_methods  payment_methods[]

  // Knowledge Management System — relation names match knowledge model side
  knowledge_author               knowledge[]                @relation("KnowledgeAuthor")
  knowledge_reviewer             knowledge[]                @relation("KnowledgeReviewer")
  knowledge_comments             knowledge_comments[]
  knowledge_versions_creator     knowledge_versions[]       @relation("KnowledgeVersionCreator")
  knowledge_workflows_assignee   knowledge_workflows[]      @relation("KnowledgeAssign")
  knowledge_workflows_reviewer   knowledge_workflows[]      @relation("KnowledgeWorkflowReview")
  knowledge_workflow_history     knowledge_workflow_history[]

  @@index([deleted_at])
  @@index([created_at])
}

model sessions {
  id               String    @id @default(uuid())
  user_id          String
  workspace_id     String?
  ip_address       String?
  user_agent       String?
  expires_at       DateTime
  last_activity_at DateTime  @default(now())
  created_at       DateTime  @default(now())

  user             users     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([expires_at])
}

model refresh_tokens {
  id         String    @id @default(uuid())
  user_id    String
  token_hash String    @unique
  expires_at DateTime
  revoked_at DateTime?
  created_at DateTime  @default(now())

  user       users     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([token_hash])
}

model password_reset_tokens {
  id         String    @id @default(uuid())
  user_id    String
  token_hash String    @unique
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime  @default(now())

  @@index([token_hash])
  @@index([user_id])
}

model roles {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  user_roles       user_roles[]
  role_permissions role_permissions[]

  @@index([slug])
}

model permissions {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String?
  domain      String
  created_at  DateTime  @default(now())

  role_permissions role_permissions[]

  @@index([slug])
  @@index([domain])
}

model role_permissions {
  id            String      @id @default(uuid())
  role_id       String
  permission_id String

  role          roles       @relation(fields: [role_id], references: [id], onDelete: Cascade)
  permission    permissions @relation(fields: [permission_id], references: [id], onDelete: Cascade)

  @@unique([role_id, permission_id])
}

model user_roles {
  id           String   @id @default(uuid())
  user_id      String
  role_id      String
  workspace_id String

  user         users    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  role         roles    @relation(fields: [role_id], references: [id], onDelete: Cascade)

  @@unique([user_id, role_id, workspace_id])
  @@index([user_id, workspace_id])
}

// ============================================================
// WORKSPACE DOMAIN
// ============================================================

model workspaces {
  id         String    @id @default(uuid())
  code       String    @unique
  name       String
  created_by String
  updated_by String?
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  members      workspace_members[]
  invitations  workspace_invitations[]
  settings     workspace_settings?
  projects     projects[]
  subscriptions subscriptions[]
  usage_logs   usage_logs[]
  invoices     invoices[]
  calculations calculations[]
  files        files[]
  api_keys     api_keys[]
  webhooks     webhooks[]
  audit_logs   audit_logs[]
  conversations conversations[]
  ai_usage     ai_usage[]
  orders       orders[]
  payment_methods      payment_methods[]
  subscription_payments subscription_payments[]
  knowledge            knowledge[]
  knowledge_objects    knowledge_objects[]

  @@index([code])
  @@index([created_by])
  @@index([deleted_at])
}

model workspace_members {
  id           String   @id @default(uuid())
  workspace_id String
  user_id      String
  role         String   @default("MEMBER")
  joined_at    DateTime @default(now())

  workspace    workspaces @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  user         users      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([workspace_id, user_id])
  @@index([workspace_id])
  @@index([user_id])
}

model workspace_invitations {
  id           String   @id @default(uuid())
  workspace_id String
  email        String
  role         String   @default("MEMBER")
  token        String   @unique
  invited_by   String
  status       String   @default("pending")
  expires_at   DateTime
  created_at   DateTime @default(now())

  workspace    workspaces @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  inviter      users      @relation("InvitedBy", fields: [invited_by], references: [id])

  @@index([workspace_id])
  @@index([token])
  @@index([email])
}

model workspace_settings {
  id           String   @id @default(uuid())
  workspace_id String   @unique
  settings     Json     @default("{}")
  updated_at   DateTime @updatedAt

  workspace    workspaces @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
}

// ============================================================
// SUBSCRIPTION DOMAIN
// ============================================================

model plans {
  id            String    @id @default(uuid())
  name          String
  slug          String    @unique
  monthly_price Decimal   @default(0) @db.Decimal(10, 2)
  yearly_price  Decimal   @default(0) @db.Decimal(10, 2)
  features      Json      @default("{}")
  is_active     Boolean   @default(true)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  subscriptions subscriptions[]
  feature_flags feature_flags[]

  @@index([slug])
  @@index([is_active])
}

model subscriptions {
  id           String    @id @default(uuid())
  workspace_id String
  plan_id      String
  status       String    @default("active")
  starts_at    DateTime  @default(now())
  ends_at      DateTime?
  cancelled_at DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  workspace    workspaces @relation(fields: [workspace_id], references: [id])
  plan         plans      @relation(fields: [plan_id], references: [id])
  payments     subscription_payments[]

  @@index([workspace_id])
  @@index([status])
}

model usage_logs {
  id           String   @id @default(uuid())
  workspace_id String
  feature      String
  amount       Int      @default(1)
  logged_at    DateTime @default(now())

  workspace    workspaces @relation(fields: [workspace_id], references: [id])

  @@index([workspace_id])
  @@index([feature])
  @@index([logged_at])
}

// ============================================================
// BILLING DOMAIN
// ============================================================

model invoices {
  id             String    @id @default(uuid())
  workspace_id   String
  invoice_number String    @unique
  status         String    @default("pending")
  currency       String    @default("USD")
  subtotal       Decimal   @db.Decimal(12, 2)
  tax_amount     Decimal   @default(0) @db.Decimal(12, 2)
  total_amount   Decimal   @db.Decimal(12, 2)
  issued_at      DateTime  @default(now())
  due_at         DateTime?
  paid_at        DateTime?
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  workspace      workspaces   @relation(fields: [workspace_id], references: [id])
  payments       payments[]
  subscription_payments subscription_payments[]

  @@index([workspace_id])
  @@index([status])
  @@index([invoice_number])
}

model payments {
  id               String    @id @default(uuid())
  workspace_id     String
  invoice_id       String
  gateway          String
  authority        String?
  reference_number String?
  amount           Decimal   @db.Decimal(12, 2)
  status           String    @default("pending")
  paid_at          DateTime?
  created_at       DateTime  @default(now())

  invoice          invoices     @relation(fields: [invoice_id], references: [id])
  transactions     transactions[]
  subscription_payments subscription_payments[]

  @@index([workspace_id])
  @@index([invoice_id])
  @@index([status])
}

model transactions {
  id         String   @id @default(uuid())
  workspace_id String
  payment_id String
  type       String
  amount     Decimal  @db.Decimal(12, 2)
  status     String   @default("pending")
  metadata   Json     @default("{}")
  created_at DateTime @default(now())

  payment    payments @relation(fields: [payment_id], references: [id])

  @@index([workspace_id])
  @@index([payment_id])
}

model payment_methods {
  id              String   @id @default(uuid())
  workspace_id    String
  user_id         String
  gateway         String   // zarinpal | payping
  gateway_customer_id String? // token/customer_id from gateway
  masked_number   String?  // e.g. "****1234"
  card_holder_name String?
  is_default      Boolean  @default(false)
  expires_at      DateTime?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
  deleted_at      DateTime?

  workspace       workspaces @relation(fields: [workspace_id], references: [id])
  user            users      @relation(fields: [user_id], references: [id])

  @@index([workspace_id])
  @@index([user_id])
  @@index([gateway])
  @@index([is_default])
}

model subscription_payments {
  id              String    @id @default(uuid())
  workspace_id    String
  subscription_id String
  invoice_id      String?
  payment_id      String?
  amount          Decimal   @db.Decimal(12, 2)
  currency        String    @default("USD")
  status          String    @default("pending") // pending | paid | failed | refunded
  period_start    DateTime?
  period_end      DateTime?
  paid_at         DateTime?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  workspace       workspaces    @relation(fields: [workspace_id], references: [id])
  subscription    subscriptions @relation(fields: [subscription_id], references: [id])
  invoice         invoices?     @relation(fields: [invoice_id], references: [id])
  payment         payments?     @relation(fields: [payment_id], references: [id])

  @@index([workspace_id])
  @@index([subscription_id])
  @@index([status])
  @@index([period_start])
}

// ============================================================
// PROJECT DOMAIN
// ============================================================

model projects {
  id           String    @id @default(uuid())
  workspace_id String
  name         String
  description  String?
  status       String    @default("active")
  start_date   DateTime?
  end_date     DateTime?
  created_by   String
  updated_by   String?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  deleted_at   DateTime?

  workspace    workspaces      @relation(fields: [workspace_id], references: [id])
  creator      users           @relation("ProjectCreatedBy", fields: [created_by], references: [id])
  members      project_members[]
  notes        project_notes[]
  reports      project_reports[]
  calculations calculations[]

  @@index([workspace_id])
  @@index([status])
  @@index([deleted_at])
}

model project_members {
  id         String   @id @default(uuid())
  project_id String
  user_id    String
  role       String   @default("viewer")
  joined_at  DateTime @default(now())

  project    projects @relation(fields: [project_id], references: [id], onDelete: Cascade)
  user       users    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([project_id, user_id])
  @@index([project_id])
}

model project_notes {
  id         String   @id @default(uuid())
  project_id String
  content    String
  created_by String
  created_at DateTime @default(now())

  project    projects @relation(fields: [project_id], references: [id], onDelete: Cascade)
  author     users    @relation(fields: [created_by], references: [id])

  @@index([project_id])
}

model project_reports {
  id         String   @id @default(uuid())
  project_id String
  file_id    String?
  created_at DateTime @default(now())

  project    projects @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@index([project_id])
}

// ============================================================
// ENGINEERING DOMAIN
// ============================================================

model calculations {
  id               String   @id @default(uuid())
  workspace_id     String
  project_id       String?
  user_id          String
  type             String
  version          String
  inputs           Json     @default("{}")
  results          Json     @default("{}")
  engine_version   String
  standard_version String
  created_at       DateTime @default(now())

  workspace        workspaces @relation(fields: [workspace_id], references: [id])
  project          projects?  @relation(fields: [project_id], references: [id])
  user             users      @relation(fields: [user_id], references: [id])

  @@index([workspace_id])
  @@index([project_id])
  @@index([type])
  @@index([created_at])
}

model calculation_templates {
  id         String   @id @default(uuid())
  name       String
  type       String
  schema     Json     @default("{}")
  created_at DateTime @default(now())

  @@index([type])
}

model engineering_standards {
  id           String    @id @default(uuid())
  code         String    @unique
  title        String
  organization String
  version      String
  published_at DateTime?
  status       String    @default("active")

  knowledge    knowledge_standards[]

  @@index([code])
  @@index([organization])
}

// ============================================================
// AI DOMAIN
// ============================================================

model agents {
  id         String   @id @default(uuid())
  name       String
  slug       String   @unique
  version    String
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())

  conversations conversations[]
  ai_usage      ai_usage[]

  @@index([slug])
}

model conversations {
  id           String   @id @default(uuid())
  workspace_id String
  agent_id     String
  title        String?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  workspace    workspaces @relation(fields: [workspace_id], references: [id])
  agent        agents     @relation(fields: [agent_id], references: [id])
  messages     messages[]

  @@index([workspace_id])
  @@index([agent_id])
}

model messages {
  id              String   @id @default(uuid())
  conversation_id String
  role            String
  content         String
  metadata        Json     @default("{}")
  created_at      DateTime @default(now())

  conversation    conversations @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  @@index([conversation_id])
}

model ai_usage {
  id                String   @id @default(uuid())
  workspace_id      String
  user_id           String
  agent_id          String?
  provider          String
  model             String
  prompt_tokens     Int      @default(0)
  completion_tokens Int      @default(0)
  total_tokens      Int      @default(0)
  cost              Decimal  @default(0) @db.Decimal(10, 6)
  created_at        DateTime @default(now())

  workspace    workspaces @relation(fields: [workspace_id], references: [id])
  user         users      @relation(fields: [user_id], references: [id])
  agent        agents?    @relation(fields: [agent_id], references: [id])

  @@index([workspace_id])
  @@index([user_id])
  @@index([created_at])
}

// ============================================================
// KNOWLEDGE DOMAIN
// ============================================================

// ──────────────────────────────────────────────────────────────
// TAXONOMY — Multi-dimensional classification
// ──────────────────────────────────────────────────────────────

model categories {
  id         String      @id @default(uuid())
  parent_id  String?
  slug       String      @unique
  name       String
  name_en    String?
  icon       String?
  color      String?
  sort_order Int         @default(0)
  is_active  Boolean     @default(true)
  created_at DateTime    @default(now())
  updated_at DateTime    @updatedAt

  level      Int         @default(1)
  parent    categories?  @relation("CategoryTree", fields: [parent_id], references: [id])
  children  categories[] @relation("CategoryTree")

  @@index([slug])
  @@index([parent_id])
  @@index([level])
  @@index([is_active])
}

model topics {
  id         String   @id @default(uuid())
  slug       String   @unique
  name       String
  name_en    String?
  icon       String?
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([slug])
}

model tags {
  id         String   @id @default(uuid())
  slug       String   @unique
  name       String
  name_en    String?
  created_at DateTime @default(now())

  @@index([slug])
}

model disciplines {
  id         String   @id @default(uuid())
  slug       String   @unique
  name       String
  name_en    String?
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([slug])
}

model audiences {
  id          String   @id @default(uuid())
  slug        String   @unique
  name        String
  name_en     String?
  description String?
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([slug])
}

// ═══════════════════════════════════════════════════════════════
// KNOWLEDGE MANAGEMENT SYSTEM
// ═══════════════════════════════════════════════════════════════

model knowledge {
  id            String    @id @default(uuid())
  workspace_id  String
  slug          String    @unique
  status        String    @default("draft")
  visibility    String    @default("public")
  language      String    @default("fa")
  version       Int       @default(1)
  is_active     Boolean   @default(true)

  // Block-based content (JSON)
  content       Json      @default("{}")

  // Full-text search helper (auto-populated)
  search_text   String?

  reading_time  Int?
  difficulty    String?
  author_id     String?
  reviewer_id   String?

  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  published_at  DateTime?
  reviewed_at   DateTime?
  archived_at   DateTime?

  author        users?                    @relation("KnowledgeAuthor", fields: [author_id], references: [id])
  reviewer      users?                    @relation("KnowledgeReviewer", fields: [reviewer_id], references: [id])

  translations  knowledge_translations[]
  taxonomy      knowledge_taxonomy[]
  media         knowledge_media[]
  formulas      knowledge_formulas[]
  examples      knowledge_examples[]
  standards     knowledge_standards[]
  versions      knowledge_versions[]
  comments      knowledge_comments[]
  workflow      knowledge_workflows?
  analytics     knowledge_analytics?

  workspace     workspaces @relation(fields: [workspace_id], references: [id])

  @@index([slug])
  @@index([workspace_id])
  @@index([status])
  @@index([visibility])
  @@index([language])
  @@index([difficulty])
  @@index([author_id])
}

model knowledge_translations {
  id              String   @id @default(uuid())
  knowledge_id    String
  language        String   @default("fa")
  title           String
  summary         String?
  seo_title       String?
  seo_description String?

  // Translated block-based content
  content         Json     @default("{}")

  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  knowledge       knowledge @relation(fields: [knowledge_id], references: [id], onDelete: Cascade)

  @@unique([knowledge_id, language])
  @@index([knowledge_id])
  @@index([language])
}

model knowledge_taxonomy {
  id            String   @id @default(uuid())
  knowledge_id  String
  taxonomy_type String   // category | topic | tag | discipline | audience
  taxonomy_id   String

  knowledge     knowledge @relation(fields: [knowledge_id], references: [id], onDelete: Cascade)

  @@unique([knowledge_id, taxonomy_type, taxonomy_id])
  @@index([knowledge_id])
  @@index([taxonomy_type])
  @@index([taxonomy_id])
}

model knowledge_media {
  id          String   @id @default(uuid())
  knowledge_id String
  type        String   // image | pdf | video | cad | 3d | gif | svg | audio | archive
  url         String
  caption_fa  String?
  caption_en  String?
  alt_fa      String?
  alt_en      String?
  description String?
  license     String?
  source      String?
  file_size   Int?
  mime_type   String?
  sort_order  Int      @default(0)
  created_at  DateTime @default(now())

  knowledge   knowledge @relation(fields: [knowledge_id], references: [id], onDelete: Cascade)

  @@index([knowledge_id])
  @@index([type])
}

model knowledge_formulas {
  id              String   @id @default(uuid())
  knowledge_id    String
  latex           String
  mathml          String?
  description_fa  String?
  description_en  String?
  variables       Json     @default("[]")
  calculator_type String?  // e.g. "BASIC-001", "CABLE-003"
  sort_order      Int      @default(0)
  created_at      DateTime @default(now())

  knowledge       knowledge @relation(fields: [knowledge_id], references: [id], onDelete: Cascade)

  @@index([knowledge_id])
  @@index([calculator_type])
}

model knowledge_examples {
  id              String   @id @default(uuid())
  knowledge_id    String
  title_fa        String
  title_en        String?
  difficulty      String   @default("basic")
  steps           Json     @default("[]")
  answer          Json?
  calculator_type String?
  sort_order      Int      @default(0)
  created_at      DateTime @default(now())

  knowledge       knowledge @relation(fields: [knowledge_id], references: [id], onDelete: Cascade)

  @@index([knowledge_id])
}

model knowledge_standards {
  knowledge_id String
  standard_id  String

  knowledge    knowledge             @relation(fields: [knowledge_id], references: [id], onDelete: Cascade)
  standard     engineering_standards @relation(fields: [standard_id], references: [id], onDelete: Cascade)

  @@id([knowledge_id, standard_id])
  @@index([knowledge_id])
  @@index([standard_id])
}

model knowledge_versions {
  id           String   @id @default(uuid())
  knowledge_id String
  version      Int
  snapshot     Json     // full content copy
  comment      String?
  created_by   String?
  created_at   DateTime @default(now())

  knowledge    knowledge @relation(fields: [knowledge_id], references: [id], onDelete: Cascade)
  creator      users?    @relation("KnowledgeVersionCreator", fields: [created_by], references: [id])

  @@unique([knowledge_id, version])
  @@index([knowledge_id])
  @@index([created_at])
}

model knowledge_comments {
  id           String    @id @default(uuid())
  knowledge_id String
  user_id      String
  parent_id    String?
  content      String
  likes        Int       @default(0)
  liked_by     Json      @default("[]")
  is_edited    Boolean   @default(false)
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  deleted_at   DateTime?

  knowledge    knowledge                @relation(fields: [knowledge_id], references: [id], onDelete: Cascade)
  user         users                    @relation(fields: [user_id], references: [id])
  parent       knowledge_comments?      @relation("KnowledgeCommentReplies", fields: [parent_id], references: [id])
  replies      knowledge_comments[]     @relation("KnowledgeCommentReplies")

  @@index([knowledge_id])
  @@index([user_id])
  @@index([parent_id])
  @@index([created_at])
}

model knowledge_workflows {
  id             String   @id @default(uuid())
  knowledge_id   String   @unique
  current_status String   @default("draft")
  assigned_to    String?
  reviewer_id    String?
  review_comment String?
  reviewed_at    DateTime?
  submitted_at   DateTime?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  knowledge      knowledge                   @relation(fields: [knowledge_id], references: [id], onDelete: Cascade)
  assignee       users?                      @relation("KnowledgeAssign", fields: [assigned_to], references: [id])
  reviewer       users?                      @relation("KnowledgeWorkflowReview", fields: [reviewer_id], references: [id])
  history        knowledge_workflow_history[]

  @@index([knowledge_id])
  @@index([current_status])
  @@index([assigned_to])
  @@index([reviewer_id])
}

model knowledge_workflow_history {
  id          String   @id @default(uuid())
  workflow_id String
  status      String
  comment     String?
  user_id     String
  created_at  DateTime @default(now())

  workflow    knowledge_workflows @relation(fields: [workflow_id], references: [id], onDelete: Cascade)
  user        users               @relation(fields: [user_id], references: [id])

  @@index([workflow_id])
  @@index([user_id])
  @@index([created_at])
}

model knowledge_analytics {
  id              String   @id @default(uuid())
  knowledge_id    String   @unique
  views           Int      @default(0)
  unique_views    Int      @default(0)
  likes           Int      @default(0)
  bookmarks       Int      @default(0)
  shares          Int      @default(0)
  downloads       Int      @default(0)
  avg_reading_time Int?
  last_viewed_at  DateTime?
  daily_stats     Json     @default("{}")
  updated_at      DateTime @updatedAt

  knowledge       knowledge @relation(fields: [knowledge_id], references: [id], onDelete: Cascade)

  @@index([knowledge_id])
}

// ═══════════════════════════════════════════════════════════════
// KNOWLEDGE OBJECTS — UMS (Universal Metadata Schema)
// ═══════════════════════════════════════════════════════════════

model knowledge_objects {
  id                String    @id @default(uuid())
  xid               String    @unique
  workspace_id      String
  title             String
  slug              String    @unique
  language          String    @default("fa")
  tier              String    @default("bronze") // platinum | gold | silver | bronze
  taxonomy          Json      @default("[]")
  ontology_refs     Json      @default("[]")
  document_version  Int       @default(1)
  checksum          String?
  publication_date  DateTime?
  effective_date    DateTime?
  status            String    @default("active") // active | superseded | deprecated | withdrawn | archived
  license           String?
  authority_score   Float     @default(0.0)
  engineering_domain String?
  semantic_tags     Json      @default("[]")
  citations         Json      @default("[]")
  source_url        String?
  storage_path      String?
  content           Json      @default("{}")
  search_text       String?
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  workspace         workspaces          @relation(fields: [workspace_id], references: [id])
  provenance        provenance_records[]
  versions          knowledge_object_versions[]

  @@index([xid])
  @@index([slug])
  @@index([workspace_id])
  @@index([status])
  @@index([language])
  @@index([tier])
  @@index([engineering_domain])
  @@index([authority_score])
}

model knowledge_object_versions {
  id                  String              @id @default(uuid())
  knowledge_object_id String
  version             Int
  status              String              @default("active") // active | superseded | deprecated | withdrawn | archived
  snapshot            Json
  comment             String?
  created_by          String?
  created_at          DateTime            @default(now())

  knowledge_object    knowledge_objects   @relation(fields: [knowledge_object_id], references: [id], onDelete: Cascade)

  @@unique([knowledge_object_id, version])
  @@index([knowledge_object_id])
  @@index([status])
  @@index([created_at])
}

// ═══════════════════════════════════════════════════════════════
// PROVENANCE STORAGE
// ═══════════════════════════════════════════════════════════════

model provenance_records {
  id                  String   @id @default(uuid())
  knowledge_object_id String
  source_document     String?
  page                Int?
  section             String?
  paragraph           String?
  chunk_id            String?
  pipeline_version    String?
  parser_version      String?
  embedding_version   String?
  citation_chain      Json     @default("[]")
  trace_id            String?
  created_at          DateTime @default(now())

  knowledge_object    knowledge_objects @relation(fields: [knowledge_object_id], references: [id], onDelete: Cascade)

  @@index([knowledge_object_id])
  @@index([trace_id])
  @@index([source_document])
  @@index([chunk_id])
}

// ═══════════════════════════════════════════════════════════════
// ONTOLOGY STORAGE
// ═══════════════════════════════════════════════════════════════

model ontology_entities {
  id            String   @id @default(uuid())
  iri           String   @unique
  canonical_id  String   @unique
  label         String
  description   String?
  entity_type   String?
  confidence    Float    @default(0.0)
  evidence      Json     @default("{}")
  metadata      Json     @default("{}")
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  synonyms      ontology_synonyms[]
  source_rels   ontology_relationships[] @relation("OntologySource")
  target_rels   ontology_relationships[] @relation("OntologyTarget")

  @@index([iri])
  @@index([canonical_id])
  @@index([entity_type])
  @@index([label])
}

model ontology_synonyms {
  id           String            @id @default(uuid())
  entity_id    String
  alias        String
  language     String            @default("fa")
  is_preferred Boolean           @default(false)

  entity       ontology_entities @relation(fields: [entity_id], references: [id], onDelete: Cascade)

  @@unique([entity_id, alias, language])
  @@index([entity_id])
  @@index([alias])
}

model ontology_relationships {
  id                String            @id @default(uuid())
  source_entity_id  String
  target_entity_id  String
  relationship_type String
  confidence        Float             @default(0.0)
  evidence          Json              @default("{}")
  created_at        DateTime          @default(now())

  source_entity     ontology_entities @relation("OntologySource", fields: [source_entity_id], references: [id], onDelete: Cascade)
  target_entity     ontology_entities @relation("OntologyTarget", fields: [target_entity_id], references: [id], onDelete: Cascade)

  @@index([source_entity_id])
  @@index([target_entity_id])
  @@index([relationship_type])
}

// ============================================================
// MARKETPLACE DOMAIN
// ============================================================

model vendors {
  id         String   @id @default(uuid())
  name       String
  slug       String   @unique
  status     String   @default("active")
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  products   products[]

  @@index([slug])
}

model products {
  id             String   @id @default(uuid())
  vendor_id      String
  type           String
  category       String?                    // engineering category: cable, transformer, mccb, fuse, switchgear, lighting, ppe, etc.
  specifications Json?                      // key-value pairs: { "cable_size_mm2": "35", "current_rating_a": "150", "voltage_rating_v": "1000" }
  sku            String   @unique
  price          Decimal  @db.Decimal(12, 2)
  currency       String   @default("USD")
  status         String   @default("active")
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
  deleted_at     DateTime?

  vendor       vendors               @relation(fields: [vendor_id], references: [id])
  translations product_translations[]
  order_items  order_items[]

  @@index([vendor_id])
  @@index([status])
  @@index([sku])
  @@index([category])
}

model product_translations {
  id          String   @id @default(uuid())
  product_id  String
  locale      String
  title       String
  description String?

  product     products @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@unique([product_id, locale])
}

model orders {
  id           String   @id @default(uuid())
  workspace_id String
  user_id      String
  status       String   @default("pending")
  currency     String   @default("USD")
  total_amount Decimal  @db.Decimal(12, 2)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  workspace    workspaces    @relation(fields: [workspace_id], references: [id])
  user         users         @relation(fields: [user_id], references: [id])
  items        order_items[]

  @@index([workspace_id])
  @@index([user_id])
  @@index([status])
}

model order_items {
  id         String  @id @default(uuid())
  order_id   String
  product_id String
  quantity   Int     @default(1)
  unit_price Decimal @db.Decimal(12, 2)
  total_price Decimal @db.Decimal(12, 2)

  order      orders   @relation(fields: [order_id], references: [id], onDelete: Cascade)
  product    products @relation(fields: [product_id], references: [id])

  @@index([order_id])
}

// ============================================================
// STORAGE DOMAIN
// ============================================================

model files {
  id            String   @id @default(uuid())
  workspace_id  String
  bucket        String
  path          String
  filename      String
  original_name String
  extension     String
  mime_type     String
  size          BigInt
  checksum      String?
  uploaded_by   String
  created_at    DateTime @default(now())
  deleted_at    DateTime?

  workspace     workspaces     @relation(fields: [workspace_id], references: [id])
  uploader      users          @relation(fields: [uploaded_by], references: [id])
  versions      file_versions[]

  @@index([workspace_id])
  @@index([uploaded_by])
  @@index([mime_type])
}

model file_versions {
  id         String   @id @default(uuid())
  file_id    String
  version    Int      @default(1)
  path       String
  checksum   String?
  created_at DateTime @default(now())

  file       files    @relation(fields: [file_id], references: [id], onDelete: Cascade)

  @@index([file_id])
}

// ============================================================
// API DOMAIN
// ============================================================

model api_keys {
  id           String    @id @default(uuid())
  workspace_id String
  name         String
  key_hash     String    @unique
  last_used_at DateTime?
  expires_at   DateTime?
  created_at   DateTime  @default(now())

  workspace    workspaces @relation(fields: [workspace_id], references: [id], onDelete: Cascade)

  @@index([workspace_id])
  @@index([key_hash])
}

model webhooks {
  id           String   @id @default(uuid())
  workspace_id String
  url          String
  secret       String?
  events       Json     @default("[]")
  is_active    Boolean  @default(true)
  created_at   DateTime @default(now())

  workspace    workspaces @relation(fields: [workspace_id], references: [id], onDelete: Cascade)

  @@index([workspace_id])
}

// ============================================================
// NOTIFICATION DOMAIN
// ============================================================

model notifications {
  id         String    @id @default(uuid())
  user_id    String
  type       String
  channel    String
  title      String
  content    String
  status     String    @default("pending")
  sent_at    DateTime?
  created_at DateTime  @default(now())

  user       users     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([status])
  @@index([created_at])
}

// ============================================================
// ADMIN DOMAIN
// ============================================================

model system_settings {
  id         String   @id @default(uuid())
  key        String   @unique
  value      String
  updated_at DateTime @updatedAt

  @@index([key])
}

model feature_flags {
  id           String    @id @default(uuid())
  name         String    @unique
  description  String?
  enabled      Boolean   @default(false)
  plan_id      String?
  workspace_id String?
  created_at   DateTime  @default(now())

  plan         plans?    @relation(fields: [plan_id], references: [id])

  @@index([name])
}

model audit_logs {
  id           String   @id @default(uuid())
  workspace_id String?
  user_id      String?
  ip_address   String?
  user_agent   String?
  action       String
  entity       String?
  entity_id    String?
  old_values   Json?
  new_values   Json?
  metadata     Json?
  created_at   DateTime @default(now())

  workspace    workspaces? @relation(fields: [workspace_id], references: [id])
  user         users?      @relation(fields: [user_id], references: [id])

  @@index([workspace_id])
  @@index([user_id])
  @@index([action])
  @@index([created_at])
}
