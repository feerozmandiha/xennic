{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "../../packages/openapi/v1/openapi.json"]
    },

    "dev": {
      "cache": false,
      "persistent": true
    },

    "lint": {
      "outputs": []
    },

    "test": {
      "dependsOn": ["build"],
      "outputs": ["coverage/**"]
    },

    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    },

    "clean": {
      "cache": false
    }
  }
}
