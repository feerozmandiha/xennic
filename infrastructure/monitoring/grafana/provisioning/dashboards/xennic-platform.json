{
  "title": "Xennic Platform Overview",
  "uid": "xennic-platform-overview",
  "version": 1,
  "schemaVersion": 39,
  "tags": ["xennic", "platform"],
  "timezone": "browser",
  "panels": [
    {
      "title": "API Request Rate",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "rate(http_requests_total[5m])", "legendFormat": "{{method}} {{path}}" }],
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 }
    },
    {
      "title": "API Latency (p95)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95" }],
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 }
    },
    {
      "title": "Active Users",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "active_users", "legendFormat": "Users" }],
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 }
    },
    {
      "title": "In-Flight Requests",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "http_requests_in_flight", "legendFormat": "in-flight" }],
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 }
    },
    {
      "title": "DB Query Duration (p95)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "histogram_quantile(0.95, sum(rate(db_query_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95" }],
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 }
    },
    {
      "title": "Cache Hit Ratio",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "rate(cache_hits_total[5m]) / (rate(cache_hits_total[5m]) + rate(cache_misses_total[5m])) * 100", "legendFormat": "hit ratio" }],
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 }
    },
    {
      "title": "DB Connections Active",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "db_connections_active", "legendFormat": "connections" }],
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 }
    },
    {
      "title": "Active Workspaces",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "active_workspaces", "legendFormat": "Workspaces" }],
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 4 }
    }
  ]
}